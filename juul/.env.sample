## Cloudflare / DNS
DO_AUTH_TOKEN=
CF_DNS_API_TOKEN=

## Traefik basic auth (generate with: htpasswd -nb user pass | sed 's/\$/\$\$/g')
HTTP_AUTH=

## Tailscale
TS_AUTHKEY=

## Grafana
GF_SECURITY_ADMIN_PASSWORD=

## Jenkins (used by OTel collector to scrape metrics)
JENKINS_USER=
JENKINS_PASSWORD=

## Docker GID (for Jenkins Docker socket access)
# DOCKER_GID=988

## Persistent data directory
DATA_DIR=

## Cherryblossom (Tailscale IP, used only by VictoriaMetrics which can't resolve MagicDNS)
CHERRYBLOSSOM_IP=
