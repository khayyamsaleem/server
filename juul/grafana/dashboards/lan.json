{
  "uid": "lan-701-maple",
  "title": "701 Maple Hill Drive LAN",
  "tags": ["lan", "network"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Devices Online",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "count(net_icmp_rtt_best{job=\"network\"} > 0)",
          "legendFormat": ""
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg Latency",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "avg(net_icmp_rtt_mean{job=\"network\"})",
          "legendFormat": ""
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.1 }] }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Packet Loss",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "avg(net_icmp_loss{job=\"network\"})",
          "legendFormat": ""
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.1 }] }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Gateway Latency",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "net_icmp_rtt_mean{name=\"xfinity-gateway\"}",
          "legendFormat": ""
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.005 }, { "color": "red", "value": 0.05 }] }
        }
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Device Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 5,
      "type": "table",
      "title": "All Devices",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "net_icmp_rtt_mean{job=\"network\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "net_icmp_rtt_best{job=\"network\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "expr": "net_icmp_loss{job=\"network\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "name" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "job 1": true, "job 2": true, "job 3": true, "instance 1": true, "instance 2": true, "instance 3": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "host 1": true, "host 2": true, "host 3": true },
            "indexByName": { "name": 0, "device_type 1": 1, "vendor 1": 2, "Value #A": 3, "Value #B": 4, "Value #C": 5 },
            "renameByName": {
              "name": "Device",
              "device_type 1": "Type",
              "vendor 1": "Vendor",
              "Value #A": "Avg RTT",
              "Value #B": "Best RTT",
              "Value #C": "Packet Loss"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Avg RTT" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "Best RTT" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 }] },
          {
            "matcher": { "id": "byName", "options": "Packet Loss" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "ICMP Latency - Infrastructure",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "net_icmp_rtt_mean{device_type=~\"router|server|network\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "ICMP Latency - Media & IoT",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "net_icmp_rtt_mean{device_type=~\"media|iot|printer|mobile\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Packet Loss",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Packet Loss by Device",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "net_icmp_loss{job=\"network\"} > 0",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 30, "drawStyle": "bars" },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 104,
      "type": "row",
      "title": "Service Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
    },
    {
      "id": 9,
      "type": "state-timeline",
      "title": "TCP Service Availability",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "net_tcp_connection_status{job=\"network\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "TCP Connection Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 45 },
      "datasource": { "uid": "P4169E866C3094E38", "type": "prometheus" },
      "targets": [
        {
          "expr": "net_tcp_connection_seconds{job=\"network\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 39
}
